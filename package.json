{
  "name": "clone-tabnews",
  "version": "1.0.0",
  "description": "Projeto de implementação do https://www.tabnews.com.br para o https://curso.dev",
  "main": "index.js",
  "scripts": {
    "init": "npm run services:wait:docker && npm run services:up && npm run services:wait:database",
    "start": "next start",
    "dev": "npm run init && npm run migrations:up && next dev",
    "postdev": "npm run migrations:down && npm run services:down",
    "build": "next build",
    "test": "npm run init && concurrently -n next,jest --hide next -k -s command-jest \"next dev\" \"jest --runInBand\" --verbose",
    "postest": "npm run services:down",
    "test:watch": "jest --watchAll --runInBand --verbose",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:wait:docker": "node infra/scripts/wait-for-docker.js",
    "services:wait:database": "node infra/scripts/wait-for-postgres.js",
    "migrations:create": "node-pg-migrate -m infra/migrations create",
    "migrations:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "migrations:down": "node-pg-migrate -m infra/migrations --envPath .env.development down",
    "migrations:status": "node-pg-migrate status",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint:check": "next lint --dir .",
    "prepare": "husky",
    "commit": "cz",
    "secretlint": "npx secretlint \"**/*\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PabloLeaoDev/clone-tabnews.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/PabloLeaoDev/clone-tabnews/issues"
  },
  "homepage": "https://github.com/PabloLeaoDev/clone-tabnews#readme",
  "dependencies": {
    "async-retry": "1.3.3",
    "dotenv": "16.4.5",
    "dotenv-expand": "11.0.6",
    "next": "14.2.5",
    "node-pg-migrate": "6.2.2",
    "pg": "8.12.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "19.3.0",
    "@commitlint/config-conventional": "19.2.2",
    "@secretlint/secretlint-rule-preset-recommend": "13.0.2",
    "commitizen": "4.3.0",
    "concurrently": "8.2.2",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-jest": "28.8.0",
    "husky": "9.1.4",
    "jest": "29.7.0",
    "prettier": "3.6.2",
    "secretlint": "13.0.2"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
