{
  "name": "clone-tabnews",
  "version": "1.0.0",
  "description": "Projeto de implementação do https://www.tabnews.com.br para o https://curso.dev",
  "main": "index.js",
  "scripts": {
    "init": "npm run wait-for-docker && npm run services:up",
    "dev": "npm run init && npm run migrations:up && next dev",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:down": "docker compose -f infra/compose.yaml down",
    "build": "next build",
    "start": "next start",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "test": "npm run init && concurrently -n next,jest --hide next -k -s command-jest \"next dev\" \"jest --runInBand\" --verbose",
    "test:watch": "jest --watchAll --runInBand --verbose",
    "migrations:create": "node-pg-migrate -m infra/migrations create",
    "migrations:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "migrations:down": "node-pg-migrate -m infra/migrations --envPath .env.development down",
    "migrations:status": "node-pg-migrate status",
    "wait-for-postgres": "node infra/scripts/wait-for-postgres.js",
    "wait-for-docker": "node infra/scripts/wait-for-docker.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PabloLeaoDev/clone-tabnews.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/PabloLeaoDev/clone-tabnews/issues"
  },
  "homepage": "https://github.com/PabloLeaoDev/clone-tabnews#readme",
  "dependencies": {
    "async-retry": "^1.3.3",
    "dotenv": "^16.4.4",
    "dotenv-expand": "^11.0.6",
    "next": "^13.1.6",
    "node-pg-migrate": "^6.2.2",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "jest": "^29.6.2",
    "prettier": "^3.6.2"
  }
}